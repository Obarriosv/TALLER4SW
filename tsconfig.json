{
  "compilerOptions": {
    "module": "ES2020",
    "target": "ES2020",
    "types": [],
    "sourceMap": true,
    "strict": true,
    "moduleResolution": "bundler",
    "outDir": "./scripts",
    "rootDir": "./",
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "skipLibCheck": true
  },
  "include": ["**/*.ts"],
  "exclude": ["scripts"]
}
